{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:mathjax": "node scripts/sync-mathjax-assets.mjs",
    "sync:excalidraw": "node scripts/sync-excalidraw-assets.mjs",
    "sync:vendor": "pnpm sync:mathjax && pnpm sync:excalidraw",
    "dev": "pnpm sync:vendor && next dev --webpack",
    "build": "pnpm sync:vendor && next build",
    "lint": "pnpm exec eslint \"**/*.{ts,tsx}\"",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run --config vitest.config.ts",
    "start": "pnpm sync:vendor && next start"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/view": "^6.43.1",
    "@continuum/shared": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/onest": "^5.2.11",
    "@fontsource/unbounded": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@uiw/react-codemirror": "^4.25.10",
    "framer-motion": "^12.40.0",
    "katex": "^0.16.47",
    "lucide-react": "^0.475.0",
    "mathjax": "^4.1.2",
    "next": "16.1.6",
    "ogl": "^1.0.11",
    "pdfjs-dist": "^5.7.284",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reactflow": "^11.11.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
