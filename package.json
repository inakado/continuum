{
  "name": "continuum",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm build:backend && pnpm build:web",
    "build:backend": "docker compose -f docker-compose.prod.yml build api worker",
    "build:backend:dev": "docker compose build api worker",
    "build:backend:prod": "docker compose -f docker-compose.prod.yml build api worker",
    "build:web": "turbo build --filter=@continuum/shared --filter=web",
    "lint": "turbo lint",
    "lint:boundaries": "pnpm exec eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern --quiet",
    "typecheck": "turbo typecheck --filter=@continuum/shared --filter=web",
    "test": "turbo test",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "update:critical:web": "pnpm --filter web up next react react-dom",
    "dev:infra": "docker compose up -d postgres redis minio",
    "dev:backend": "docker compose up -d api worker",
    "dev:web": "PORT=3001 NEXT_PUBLIC_API_BASE_URL=http://localhost:3000 pnpm --filter web dev",
    "smoke": "node scripts/smoke.mjs",
    "docs:check": "pnpm docs:check:links && pnpm docs:check:index && pnpm docs:check:status",
    "docs:check:links": "node scripts/docs/check-links.mjs",
    "docs:check:index": "node scripts/docs/check-index.mjs",
    "docs:check:status": "node scripts/docs/check-status.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-boundaries": "^5.4.0",
    "turbo": "^2.8.1"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.3.6"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "argon2",
      "prisma"
    ],
    "auditConfig": {
      "ignoreCves": [
        "GHSA-3ppc-4f35-3m26"
      ]
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "msgpackr-extract"
    ]
  }
}
